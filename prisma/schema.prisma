// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum CategoryStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
  FEATURED
  INACTIVE
}

model Category {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String         @unique
  description String?
  status      CategoryStatus @default(ACTIVE)
  imageUrl    String?

  // RELATIONS
  products Product[] // One-to-Many relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BrandStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
  FEATURED
  INACTIVE
}

model Brand {
  id     String      @id @default(auto()) @map("_id") @db.ObjectId
  title  String
  slug   String      @unique
  status BrandStatus @default(ACTIVE)
  logo   String?

  // RELATIONS
  products Product[] // One-to-Many relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UnitType {
  PIECE
  KILOGRAM
  LITER
  METER
  SQUARE_METER
}

model Unit {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  shortName String   @unique
  type      UnitType

  // RELATIONS
  products Product[] // One-to-Many relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  CLOSED
}

model Warehouse {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String          @unique
  logo          String?
  contactPerson String
  status        WarehouseStatus @default(ACTIVE)
  city          String?
  country       String?
  email         String
  phone         String
  zipCode       String

  // RELATIONS
  products WarehouseProduct[] // Many-to-many relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
}

model Supplier {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String         @unique
  imageUrl    String?
  companyName String
  vatNumber   String?
  status      SupplierStatus @default(ACTIVE)
  email       String
  phone       String
  address     String
  city        String
  state       String?
  country     String?
  zipCode     String

  // RELATIONS
  products SupplierProduct[] // Many-to-many relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductTaxMethod {
  INCLUSIVE
  EXCLUSIVE
}

enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  DISCONTINUED
  PENDING
  FEATURED
}

enum BarcodeType {
  CODE128
  EAN13
  UPC
  ITF14
  EAN8
  CODE39
}

model Product {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  barcodeType  BarcodeType      @default(CODE128)
  productCode  String           @unique
  details      String
  productCost  Float
  productPrice Float
  alertQty     Int
  productTax   Float
  stockQty     Int              @default(1)
  status       ProductStatus    @default(AVAILABLE)
  taxMethod    ProductTaxMethod @default(INCLUSIVE)
  images       String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String   @db.ObjectId
  brand      Brand    @relation(fields: [brandId], references: [id])
  brandId    String   @db.ObjectId
  unit       Unit     @relation(fields: [unitId], references: [id])
  unitId     String   @db.ObjectId

  // Many-to-many relations
  warehouses WarehouseProduct[]
  suppliers  SupplierProduct[]
}

model WarehouseProduct {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  warehouseId String    @db.ObjectId
  productId   String    @db.ObjectId
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
}

model SupplierProduct {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  supplierId String   @db.ObjectId
  productId  String   @db.ObjectId
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([supplierId, productId])
}

// RELATIONS
// Category --> One to Many -- One Category can have many products
// Brand --> One to Many -- One Brand can have many products
// Unit --> One to Many -- One Unit can exists for many products
// Warehouse --> Many to Many -- Warehouse can have many products & Same Product can be available in many warehouses
// Supplier --> Many to Many -- Supplier can supply many products & Same Product can be supplied by many suppliers

enum BannerStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  PENDING
}

model Banner {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl   String
  bannerLink String
  status     BannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
